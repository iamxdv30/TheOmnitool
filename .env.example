# Flask Configuration
FLASK_ENV=development
SECRET_KEY='your-secret-key-here'
IS_LOCAL=true

# Database Configuration
# Option 1: Docker PostgreSQL (RECOMMENDED - matches staging/production)
USE_DOCKER_DB=true
DATABASE_URL='postgresql://omnitool:omnitool_dev@localhost:5432/omnitool_dev'

# Option 2: SQLite fallback (NOT RECOMMENDED - may cause migration issues)
# USE_DOCKER_DB=false
# DATABASE_URL is ignored when USE_DOCKER_DB=false

# To start Docker PostgreSQL:
#   Windows: .\scripts\docker-db.ps1 start
#   Linux/Mac: ./scripts/docker-db.sh start

# Email Configuration (REQUIRED)
MAIL_USERNAME='your-email@gmail.com'
MAIL_PASSWORD='your-app-password'
MAIL_DEFAULT_SENDER='your-email@domain.com'

# Security Configuration (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
TOKEN_SECRET_KEY='generate-with-secrets.token_hex(24)'
SECURITY_PASSWORD_SALT='generate-with-secrets.token_hex(24)'

# ReCAPTCHA Configuration (REQUIRED for registration/login)
# Get keys at: https://www.google.com/recaptcha/admin
RECAPTCHA_SITE_KEY='your-recaptcha-site-key'
RECAPTCHA_SECRET_KEY='your-recaptcha-secret-key'

# Google OAuth (Optional - for future implementation)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Password Policy Settings
MIN_PASSWORD_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_NUMBER=true
